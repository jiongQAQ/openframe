{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "pnpm install --frozen-lockfile --ignore-scripts --filter openframe-web... --filter openframe-ui...",
  "buildCommand": "if [ -f apps/web/package.json ]; then pnpm -C apps/web build && rm -rf dist && mkdir -p dist && cp -R apps/web/dist/. dist/; else pnpm build; fi",
  "devCommand": "pnpm --filter openframe-web dev",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/apps/web/api/:path*"
    }
  ],
  "functions": {
    "apps/web/api/**/*.ts": {
      "runtime": "nodejs20.x"
    }
  }
}
